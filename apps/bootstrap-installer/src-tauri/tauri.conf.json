{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LABO AI Setup",
  "version": "0.1.27",
  "identifier": "ai.labo.setup",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LABO AI Setup",
        "width": 720,
        "height": 650,
        "minWidth": 620,
        "minHeight": 570,
        "resizable": true,
        "center": true,
        "backgroundColor": "#070b0b"
      }
    ],
    "security": { "csp": "default-src 'self'; style-src 'self'; script-src 'self'" }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "category": "DeveloperTool",
    "shortDescription": "Install and update LABO AI from source",
    "longDescription": "A source-first bootstrap installer that fetches the latest LABO AI release and builds it locally.",
    "icon": ["../../../build/icon.png", "../../../build/icon.icns"],
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
